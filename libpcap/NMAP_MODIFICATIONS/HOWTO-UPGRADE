Download libpcap-X.Y.tar.gz from http://www.tcpdump.org/#latest-release
and verify the signature.

cd
# Make a copy of this directory.
cp -r ~/kmap/libpcap/KMAP_MODIFICATIONS .
tar xzvf libpcap-X.Y.tar.xz
cd kmap
rsync -rv --delete ~/libpcap-X.Y/ ~/kmap/libpcap/
# Remove some things we don't want to ship
rm -rf ~/kmap/libpcap/{rpcapd,testprogs,doc,tests}
# Apply patch to avoid those dirs
git apply ~/KMAP_MODIFICATIONS/0002-Disable-unnecessary-features.patch
git add -A libpcap
cd libpcap
autoconf
./configure
make
git add grammar.[ch] scanner.[ch]
cd ..
# Apply remaining patches.
git apply ~/KMAP_MODIFICATIONS/0001-Don-t-autogenerate-Lex-Yacc-files.patch
git apply ~/KMAP_MODIFICATIONS/0003-Rename-VERSION-file.patch
# Make changes as necessary and update the patch files
cd libpcap
autoconf
cd ..
git add -u libpcap
mv ~/KMAP_MODIFICATIONS libpcap/
git add libpcap/KMAP_MODIFICATIONS
git commit -m "Upgrade libpcap to X.Y."
