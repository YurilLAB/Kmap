# Cross-platform line-ending policy for Kmap.
#
# Goal: source files are LF-terminated regardless of which OS the developer
# checks out on. Windows-only project files keep CRLF (MSBuild/Visual Studio
# require it). Known binaries are explicitly marked so git never tries to
# convert them.
#
# After editing this file, contributors with a previously-checked-out tree
# should run:  git add --renormalize .  (or re-clone) to apply the policy.

# Default: detect text vs binary, force LF in the working tree
* text=auto eol=lf

# Windows toolchain files — must stay CRLF
*.bat           text eol=crlf
*.cmd           text eol=crlf
*.ps1           text eol=crlf
*.sln           text eol=crlf
*.vcproj        text eol=crlf
*.vcxproj       text eol=crlf
*.vcxproj.user  text eol=crlf
*.vcxproj.filters text eol=crlf
*.props         text eol=crlf
*.targets       text eol=crlf

# Image / binary blobs — never touch
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.ico           binary
*.bmp           binary
*.tiff          binary
*.pdf           binary

# Compiled / archive blobs
*.db            binary
*.sqlite        binary
*.bin           binary
*.gz            binary
*.tgz           binary
*.bz2           binary
*.xz            binary
*.zip           binary
*.tar           binary
*.7z            binary
*.exe           binary
*.dll           binary
*.so            binary
*.so.*          binary
*.dylib         binary
*.lib           binary
*.a             binary
*.o             binary
*.obj           binary
*.class         binary
*.jar           binary

# Fonts
*.eot           binary
*.otf           binary
*.ttf           binary
*.woff          binary
*.woff2         binary

# kmap-specific data files (already known-binary)
kmap-cve.db     binary
kmap-os-db      binary
kmap-mac-prefixes binary
